local Players = game:GetService("Players")
local player = Players.LocalPlayer
local mouse = player:GetMouse()

local tool = Instance.new("Tool")
tool.Name = "Card explosion"
tool.RequiresHandle = false
tool.CanBeDropped = false
tool.Parent = player.Backpack

local card
local following = false
local angle = 0
local root
local equipped = false

local function createCard()

	card = Instance.new("Part")
	card.Size = Vector3.new(16,24,1)
	card.Anchored = true
	card.CanCollide = false
	card.Material = Enum.Material.Neon
	card.Color = Color3.new(1,1,1)
	card.Parent = workspace

	local decal = Instance.new("Decal")
	decal.Texture = "rbxassetid://1880203893"
	decal.Face = Enum.NormalId.Front
	decal.Parent = card

	local decal2 = decal:Clone()
	decal2.Face = Enum.NormalId.Back
	decal2.Parent = card

	following = true
end

local function startSpin()

	task.spawn(function()
		while following and equipped and card and card.Parent do

			angle += 4

			card.CFrame =
				root.CFrame *
				CFrame.new(0,18,0) *
				CFrame.Angles(0,math.rad(angle),0)

			task.wait()
		end
	end)

end

tool.Equipped:Connect(function()

	equipped = true

	local char = player.Character or player.CharacterAdded:Wait()
	root = char:WaitForChild("HumanoidRootPart")

	createCard()
	startSpin()

end)

tool.Unequipped:Connect(function()

	equipped = false
	following = false

	if card then
		card:Destroy()
	end

end)

tool.Activated:Connect(function()

	if not following or not card then return end
	following = false

	local target = mouse.Hit.Position

	for i = 1,25 do
		card.CFrame = card.CFrame:Lerp(
			CFrame.new(target) * CFrame.Angles(math.rad(90),0,0),
			0.15
		)
		task.wait()
	end

	local explosion = Instance.new("Explosion")
	explosion.Position = target
	explosion.BlastRadius = 20
	explosion.BlastPressure = 500000
	explosion.Parent = workspace

	task.wait(1)

	if card then
		card:Destroy()
	end

	-- só cria outra carta se ainda estiver segurando a tool
	if equipped then
		task.wait(0.3)
		createCard()
		startSpin()
	end

end)

player.CharacterAdded:Connect(function()
	task.wait(1)
	tool.Parent = player.Backpack
end)








