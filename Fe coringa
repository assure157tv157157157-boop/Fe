-- Loop de animação (idle)
local function animate()
    while vereusActive do
        sine = sine + change
        if hand1Weld and hand2Weld then
            -- Animação da mão direita
            hand1Weld.C0 = hand1Weld.C0:lerp(
                CFrame.new(4.5, -5 + 0.5 * math.sin(sine/14), 6) *
                CFrame.Angles(math.rad(10 + 1 * math.sin(sine/13)), math.rad(-5 + 5 * math.sin(sine/12)), math.rad(-36 - 4 * math.sin(sine/11))),
                0.2
            )
            -- Animação da mão esquerda
            hand2Weld.C0 = hand2Weld.C0:lerp(
                CFrame.new(-5, -5 + 0.5 * math.sin(sine/14), 6) *
                CFrame.Angles(math.rad(13 - 3 * math.sin(sine/12)), math.rad(36 - 3 * math.sin(sine/13)), math.rad(35 + 2 * math.sin(sine/11))),
                0.2
            )
        end
        runService.RenderStepped:wait()
    end
end

-- Ativar Vereus
local function activateVereus()
    if vereusActive then return end
    local char = player.Character
    if not char then return end

    -- Esconder jogador
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part ~= char:FindFirstChild("HumanoidRootPart") then
            originalTransparencies[part] = part.Transparency
            part.Transparency = 1
        end
    end

    -- Criar partes se necessário
    if #vereusParts == 0 then
        createVereus()
    end

    -- Mostrar Vereus
    for _, part in ipairs(vereusParts) do
        part.Transparency = 0
    end

    vereusActive = true
    -- Iniciar animação em uma thread separada
    coroutine.wrap(animate)()
end

-- Desativar Vereus
local function deactivateVereus()
    if not vereusActive then return end
    vereusActive = false

    -- Restaurar jogador
    for part, trans in pairs(originalTransparencies) do
        if part and part.Parent then
            part.Transparency = trans
        end
    end
    originalTransparencies = {}

    -- Esconder Vereus
    for _, part in ipairs(vereusParts) do
        if part and part.Parent then
            part.Transparency = 1
        end
    end
end

-- Criar ferramenta
local function createTool()
    if tool and tool.Parent then return end

    tool = Instance.new("Tool")
    tool.Name = "Vereus Controller"
    tool.RequiresHandle = false
    tool.Parent = player.Backpack

    tool.Equipped:Connect(activateVereus)
    tool.Unequipped:Connect(deactivateVereus)  -- desativa ao desequipar
    tool.Activated:Connect(function()
        if vereusActive then
            deactivateVereus()
        end
    end)
end

-- Inicialização
player.CharacterAdded:Connect(function()
    vereusParts = {}
    hand1Weld, hand2Weld = nil, nil
    vereusActive = false
    originalTransparencies = {}
    task.wait(1)
    createTool()
end)

if player.Character then
    task.wait(1)
    createTool()
end
