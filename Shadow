    pcall(function() WearRemote:InvokeServer(tonumber(Desc.Pants)) end)  
    task.wait(0.2)  
end  
  
-- Remover face  
if tonumber(Desc.Face) then  
    pcall(function() WearRemote:InvokeServer(tonumber(Desc.Face)) end)  
    task.wait(0.2)  
end  
  
task.wait(0.5)  
print("Skin limpa!")

end

