pcall(function()

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()

local tool = Instance.new("Tool")
tool.Name = "Warp Rings"
tool.RequiresHandle = false
tool.CanBeDropped = false
tool.Parent = player.Backpack

local char
local root
local handRing
local portals = {}
local arremessando = false

-- ANEL NA MÃO
local function createHandRing()

	char = player.Character or player.CharacterAdded:Wait()
	local hand = char:FindFirstChild("RightHand")
	if not hand then return end

	handRing = Instance.new("Part")
	handRing.Shape = Enum.PartType.Cylinder
	handRing.Size = Vector3.new(0.15,1.2,1.2)
	handRing.Material = Enum.Material.Neon
	handRing.Color = Color3.fromRGB(255,220,0)
	handRing.CanCollide = false
	handRing.Anchored = false

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = handRing
	weld.Part1 = hand
	weld.Parent = handRing

	handRing.CFrame = hand.CFrame * CFrame.Angles(0,0,math.rad(90))
	handRing.Parent = char

end

-- CRIAR PORTAL
local function createPortal(position)

	local portalPos = Vector3.new(position.X, position.Y + 3, position.Z)

	local portal = Instance.new("Part")
	portal.Shape = Enum.PartType.Cylinder
	portal.Size = Vector3.new(0.5,1,1)
	portal.Anchored = true
	portal.CanCollide = false
	portal.Material = Enum.Material.Neon
	portal.Color = Color3.fromRGB(255,220,0)

	-- ORIENTAÇÃO CORRETA DO PORTAL
	portal.CFrame =
		CFrame.lookAt(portalPos, root.Position) *
		CFrame.Angles(0, math.rad(90), 0)

	portal.Parent = workspace

	-- DECAL NAS DUAS FACES
	local decal = Instance.new("Decal")
	decal.Texture = "rbxassetid://1880203893"
	decal.Face = Enum.NormalId.Front
	decal.Parent = portal

	local decal2 = decal:Clone()
	decal2.Face = Enum.NormalId.Back
	decal2.Parent = portal

	-- LUZ
	local light = Instance.new("PointLight")
	light.Color = Color3.fromRGB(255,220,0)
	light.Range = 15
	light.Brightness = 3
	light.Parent = portal

	-- PARTÍCULAS
	local particles = Instance.new("ParticleEmitter")
	particles.Texture = "rbxassetid://243660364"
	particles.Rate = 100
	particles.Speed = NumberRange.new(1,4)
	particles.Lifetime = NumberRange.new(0.5,1)
	particles.SpreadAngle = Vector2.new(360,360)
	particles.Parent = portal

	-- ANIMAÇÃO DE ABRIR
	TweenService:Create(
		portal,
		TweenInfo.new(0.8,Enum.EasingStyle.Elastic,Enum.EasingDirection.Out),
		{Size = Vector3.new(1,16,16)}
	):Play()

	table.insert(portals,portal)

	if #portals > 2 then
		local antigo = table.remove(portals,1)
		antigo:Destroy()
	end

	-- TELEPORTE
	portal.Touched:Connect(function(hit)

		local character = hit.Parent
		if character ~= char then return end
		if #portals < 2 then return end
		if char:GetAttribute("Teleporting") then return end

		char:SetAttribute("Teleporting",true)

		local rootPart = char:WaitForChild("HumanoidRootPart")
		local destino

		if portal == portals[1] then
			destino = portals[2].CFrame * CFrame.new(0,3,0)
		else
			destino = portals[1].CFrame * CFrame.new(0,3,0)
		end

		rootPart.CFrame = destino

		task.wait(1)
		char:SetAttribute("Teleporting",false)

	end)

end

-- EQUIPAR
tool.Equipped:Connect(function()

	char = player.Character or player.CharacterAdded:Wait()
	root = char:WaitForChild("HumanoidRootPart")

	createHandRing()

end)

tool.Unequipped:Connect(function()

	if handRing then
		handRing:Destroy()
		handRing = nil
	end

end)

-- JOGAR ANEL
tool.Activated:Connect(function()

	if not handRing then return end
	if arremessando then return end
	arremessando = true

	local target = mouse.Hit.Position

	local ring = Instance.new("Part")
	ring.Shape = Enum.PartType.Cylinder
	ring.Size = Vector3.new(0.15,1.2,1.2)
	ring.Material = Enum.Material.Neon
	ring.Color = Color3.fromRGB(255,220,0)
	ring.Anchored = true
	ring.CanCollide = false
	ring.CFrame = handRing.CFrame
	ring.Parent = workspace

	local tweenInfo = TweenInfo.new(0.5,Enum.EasingStyle.Linear)

	local goal = {
		CFrame = CFrame.new(target) * CFrame.Angles(0,0,math.rad(90))
	}

	local tween = TweenService:Create(ring,tweenInfo,goal)
	tween:Play()

	tween.Completed:Wait()

	local pos = ring.Position
	ring:Destroy()

	createPortal(pos)

	arremessando = false

end)

player.CharacterAdded:Connect(function()

	task.wait(1)
	tool.Parent = player:WaitForChild("Backpack")

	for _,p in ipairs(portals) do
		p:Destroy()
	end

	portals = {}

end)

end)
